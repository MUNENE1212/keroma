# ============================================================
# KEROMA — Recipes that remember.
# ============================================================

# ---- Required ----

# MongoDB Atlas connection string
MONGODB_URI=mongodb://localhost:27017/keroma

# NextAuth
NEXTAUTH_URL=https://keroma.ementech.co.ke
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ---- AI providers (at least one required for recipe generation) ----

# Anthropic Claude 3.5 Sonnet (PRIMARY — best recipe prose)
ANTHROPIC_API_KEY=

# OpenAI GPT-4o (SECONDARY fallback)
OPENAI_API_KEY=

# Google Gemini 1.5 Pro (TERTIARY fallback, free tier, multilingual)
GOOGLE_GENERATIVE_AI_API_KEY=

# Replicate Flux Schnell (HERO IMAGES — optional)
REPLICATE_API_TOKEN=

# ---- OAuth (optional but recommended) ----

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Email (transactional) ----

RESEND_API_KEY=
RESEND_FROM_EMAIL=KEROMA <hello@keroma.co.ke>

# ---- M-Pesa payments (IntaSend) ----

INTASEND_PUBLISHABLE_KEY=
INTASEND_SECRET_KEY=
INTASEND_WEBHOOK_SECRET=

# ---- Premium pricing ----

PREMIUM_PRICE_KES=199

# ---- Media CDN ----

NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Observability (optional) ----

NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=

# ---- Feature flags ----

# Set to "true" to skip live AI and use mock responses (for dev/test)
KEROMA_AI_MOCK=true